{
  "name": "next-app-boilerplate",
  "version": "1.13.0",
  "private": true,
  "author": {
    "name": "POPO He",
    "email": "chongruei@gmail.com"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "format": "prettier --cache --write './**/*.{js,jsx,ts,tsx,css,scss,md,json}' --config ./prettier.config.js",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "analyze": "ANALYZE=true next build",
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:unit": "node --experimental-test-coverage --test-coverage-lines=100 --test-coverage-branches=100 --test-coverage-functions=100 --test-coverage-include=\"src/**/*.{ts,tsx}\" --test-coverage-exclude=\"**/*.test.ts\" --test \"src/**/*.test.ts\"",
    "test:lighthouse": "lhci autorun",
    "prepare": "husky"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.101.2",
    "@types/node": "26.1.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "axios": "^1.18.1",
    "next": "16.2.10",
    "next-intl": "4.13.2",
    "next-view-transitions": "^0.3.5",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "tailwindcss": "4.3.2",
    "typescript": "6.0.3",
    "valtio": "^2.3.2"
  },
  "devDependencies": {
    "@beam-australia/react-env": "^3.1.1",
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.2.0",
    "@eslint/js": "9.39.5",
    "@lhci/cli": "^0.15.1",
    "@next/bundle-analyzer": "16.2.10",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "4.3.2",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@typescript-eslint/eslint-plugin": "^8.63.0",
    "@typescript-eslint/parser": "^8.63.0",
    "clsx": "^2.1.1",
    "eslint": "9.39.5",
    "eslint-config-next": "16.2.10",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "postcss": "8.5.16",
    "prettier": "^3.9.5",
    "prettier-plugin-tailwindcss": "^0.8.0"
  },
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=9.10.0"
  },
  "packageManager": "pnpm@9.10.0",
  "lint-staged": {
    "*.{js,jsx,mjs,cjs,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{css,scss,md,json,yml,yaml}": [
      "prettier --write"
    ]
  },
  "pnpm": {
    "overrides": {
      "minimatch@<3.1.4": ">=3.1.4 <4.0.0",
      "cross-spawn@<6.0.6": ">=6.0.6 <7.0.0",
      "flatted@<3.4.2": ">=3.4.2 <4.0.0",
      "brace-expansion@<1.1.12": ">=1.1.12 <2.0.0",
      "picomatch@<2.3.2": ">=2.3.2 <3.0.0",
      "ws@>=7.0.0 <7.5.11": ">=7.5.11 <8.0.0",
      "nanoid@<3.3.8": ">=3.3.8 <4.0.0",
      "ajv@>=7.0.0-alpha.0 <8.18.0": ">=8.18.0 <9.0.0",
      "postcss@<8.5.10": ">=8.5.10 <9.0.0"
    }
  }
}
